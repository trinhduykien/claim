<!-- ============ FLEXIBLE PATTERNS ============ -->

<!-- Trả lời "có" với nhiều biến thể -->
<category>
    <pattern>* CO *</pattern>
    <template>__ANSWER__:Có</template>
</category>

<category>
    <pattern>* KHONG *</pattern>
    <template>__ANSWER__:Không</template>
</category>

<category>
    <pattern>* KHONG RO *</pattern>
    <template>__ANSWER__:Không rõ</template>
</category>

<!-- Số tuổi (pattern số) -->
<category>
    <pattern>#</pattern>
    <template>__ANSWER__:<star/></template>
</category>

